{
  "name": "kv-skill",
  "version": "1.0.0",
  "type": "module",
  "description": "Redis key-value store operations for Claude Code",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "kv-skill": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "build:skill": "npm run build && mkdir -p skills/kv-skill/scripts && cp dist/*.js skills/kv-skill/scripts/",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "redis": "^4.6.13",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
