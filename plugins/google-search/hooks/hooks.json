{
  "description": "Auto-setup: ensure dependencies installed and scripts executable on session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/ensure-setup.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
